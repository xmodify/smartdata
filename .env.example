APP_NAME=Smartdata
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://127.0.0.1/smartdata
ASSET_URL=/smartdata
VITE_ASSET_URL=${ASSET_URL}

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=smartdata
DB_USERNAME=
DB_PASSWORD=

# HOSxP Master Connection
DB_HOST_MASTER=127.0.0.1
DB_PORT_MASTER=3306
DB_DATABASE_MASTER=hosxe
DB_USERNAME_MASTER=
DB_PASSWORD_MASTER=

# HOSxP Connection (Slave 1)
DB_HOST_SLAVE1=127.0.0.1
DB_PORT_SLAVE1=3306
DB_DATABASE_SLAVE1=hosxe
DB_USERNAME_SLAVE1=
DB_PASSWORD_SLAVE1=

# HOSxP Slave 2 Connection
DB_HOST_SLAVE2=127.0.0.1
DB_PORT_SLAVE2=3306
DB_DATABASE_SLAVE2=hosxe
DB_USERNAME_SLAVE2=
DB_PASSWORD_SLAVE2=

# BackOffice Connection
DB_HOST_BACKOFFICE=127.0.0.1
DB_PORT_BACKOFFICE=3306
DB_DATABASE_BACKOFFICE=backoffice
DB_USERNAME_BACKOFFICE=
DB_PASSWORD_BACKOFFICE=


SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/smartdata
SESSION_DOMAIN=null
SESSION_HTTP_ONLY=true
# SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
